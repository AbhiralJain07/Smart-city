# Environment variables for Smart City Command Center

# Performance settings
NEXT_PUBLIC_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_TARGET_FPS=60
NEXT_PUBLIC_HARDWARE_BASELINE="gtx1660"

# Feature flags
NEXT_PUBLIC_ENABLE_3D_VISUALIZATIONS=true
NEXT_PUBLIC_ENABLE_ANIMATIONS=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_OPTIMIZATIONS=true

# Admin authentication
ADMIN_EMAIL=admin123@gmail.com
ADMIN_PASSWORD=admin@login
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# API endpoints (for future use)
# NEXT_PUBLIC_API_BASE_URL=https://api.smartcity.ai
# NEXT_PUBLIC_WS_URL=wss://api.smartcity.ai/ws

# Analytics (optional)
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# Development settings
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_SHOW_PERFORMANCE_OVERLAY=false
